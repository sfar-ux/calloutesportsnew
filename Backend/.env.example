PORT=5000
DATABASE_URL="postgresql://user:password@localhost:5432/callout"
JWT_SECRET="your_jwt_secret_here"
JWT_EXPIRES_IN="7d"

# Firebase
FIREBASE_PROJECT_ID="call-out-esports"
FIREBASE_STORAGE_BUCKET="call-out-esports.firebasestorage.app"
FIREBASE_SERVICE_ACCOUNT_BASE64="your_base64_encoded_service_account_json"

# Razorpay
RAZORPAY_KEY_ID="your_razorpay_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
RAZORPAY_WEBHOOK_SECRET="your_razorpay_webhook_secret"
